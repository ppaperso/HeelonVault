#!/bin/bash
# Script de mise à jour sécurisé pour le Gestionnaire de mots de passe
# - Détection automatique de la source (workspace local)
# - Backup complet en tar.gz
# - Analyse des fichiers modifiés
# - Validation avant application

set -e
exec > >(tee -i /tmp/update-password-manager.log) 2>&1

# Détection automatique du dossier source (là où se trouve ce script)
SOURCE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Configuration
APP_NAME="password-manager"
INSTALL_DIR="/opt/$APP_NAME"
VENV_DIR="$INSTALL_DIR/venv"
DATA_DIR="/var/lib/${APP_NAME}-shared"
BACKUP_ROOT="/var/backups/${APP_NAME}"
BACKUP_FILE=""
REQUIREMENTS_FILE="$INSTALL_DIR/requirements.txt"
FILTERED_REQUIREMENTS=""
MAX_BACKUPS=10

# Fichiers/dossiers à exclure de la copie
EXCLUDE_PATTERNS=(
    "venv"
    "venv-dev"
    "__pycache__"
    ".git"
    ".gitignore"
    "*.pyc"
    "*.pyo"
    ".vscode"
    ".idea"
    "*.log"
    ".DS_Store"
    "update.sh"  # Ne pas écraser ce script
)

# Couleurs
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Fonction pour afficher un message d'erreur et quitter
error_exit() {
    echo -e "${RED}❌ ERREUR: $1${NC}" >&2
    echo "   Voir /tmp/update-password-manager.log pour plus de détails."
    if [ -n "$BACKUP_FILE" ] && [ -f "$BACKUP_FILE" ]; then
        echo -e "${YELLOW}⚠️  Un backup complet a été créé: $BACKUP_FILE${NC}"
        echo "   Pour restaurer en cas de problème:"
        echo "   sudo systemctl stop password-manager 2>/dev/null || pkill -f password_manager.py"
        echo "   sudo rm -rf $INSTALL_DIR"
        echo "   sudo mkdir -p $INSTALL_DIR"
        echo "   sudo tar -xzf $BACKUP_FILE -C /"
    fi
    exit 1
}

# Fonction pour afficher un titre
print_header() {
    echo ""
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BLUE}$1${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

# Nettoyage
cleanup_filtered_requirements() {
    if [ -n "$FILTERED_REQUIREMENTS" ] && [ -f "$FILTERED_REQUIREMENTS" ]; then
        rm -f "$FILTERED_REQUIREMENTS"
    fi
}

trap cleanup_filtered_requirements EXIT

# Prépare la liste des paquets pip (exclut PyGObject)
filter_pip_requirements() {
    FILTERED_REQUIREMENTS=$(mktemp)
    awk '!/^[[:space:]]*($|#)/ && $0 !~ /PyGObject/ { print }' "$REQUIREMENTS_FILE" > "$FILTERED_REQUIREMENTS"
}

echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║                                                              ║"
echo "║   🔄 MISE À JOUR DU GESTIONNAIRE DE MOTS DE PASSE           ║"
echo "║                                                              ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""
echo "  📂 Répertoire d'installation: $INSTALL_DIR"
echo "  📂 Répertoire de données: $DATA_DIR"
echo "  📂 Backups: $BACKUP_ROOT"
echo "  📝 Logs: /tmp/update-password-manager.log"
echo ""

# Vérifier que le script est lancé en root
if [ "$(id -u)" -ne 0 ]; then
    error_exit "Ce script doit être lancé avec sudo."
fi

# Vérifier que l'application est installée
if [ ! -d "$INSTALL_DIR" ]; then
    error_exit "L'application n'est pas installée dans $INSTALL_DIR. Utilisez install.sh pour l'installation initiale."
fi

if [ ! -d "$DATA_DIR" ]; then
    error_exit "Le répertoire de données $DATA_DIR n'existe pas. Installation corrompue?"
fi

# Détecter la version actuelle
print_header "📊 Détection de la version actuelle"
CURRENT_VERSION="inconnue"
if [ -f "$INSTALL_DIR/src/version.py" ]; then
    CURRENT_VERSION=$(python3 -c "import sys; sys.path.insert(0, '$INSTALL_DIR'); from src.version import __version__; print(__version__)" 2>/dev/null || echo "inconnue")
fi
echo "Version actuelle: $CURRENT_VERSION"

# Détecter la nouvelle version
NEW_VERSION="inconnue"
if [ -f "$SCRIPT_DIR/src/version.py" ]; then
    NEW_VERSION=$(python3 -c "import sys; sys.path.insert(0, '$SCRIPT_DIR'); from src.version import __version__; print(__version__)" 2>/dev/null || echo "inconnue")
fi
echo "Nouvelle version: $NEW_VERSION"

if [ "$CURRENT_VERSION" = "$NEW_VERSION" ]; then
    echo -e "${YELLOW}⚠️  Même version détectée. Continuer quand même la mise à jour? [o/N]${NC}"
    read -r response
    if [[ ! "$response" =~ ^[oO]$ ]]; then
        echo "Mise à jour annulée."
        exit 0
    fi
fi

# Créer le répertoire de backup avec timestamp
print_header "💾 Création du backup complet des données"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_DIR="$BACKUP_ROOT/backup_${CURRENT_VERSION}_to_${NEW_VERSION}_${TIMESTAMP}"
mkdir -p "$BACKUP_DIR/data" || error_exit "Impossible de créer le répertoire de backup"
mkdir -p "$BACKUP_DIR/app" || error_exit "Impossible de créer le répertoire de backup"

echo "📂 Répertoire de backup: $BACKUP_DIR"

# Backup des DONNÉES (priorité maximale!)
echo ""
echo "🔐 Sauvegarde de TOUTES les données de production..."
echo "   • Copie de $DATA_DIR"

# Compter les fichiers avant
DATA_FILE_COUNT=$(find "$DATA_DIR" -type f 2>/dev/null | wc -l)
echo "   • Fichiers à sauvegarder: $DATA_FILE_COUNT"

# Copier TOUTES les données
cp -a "$DATA_DIR"/* "$BACKUP_DIR/data/" 2>/dev/null || true
cp -a "$DATA_DIR"/.[!.]* "$BACKUP_DIR/data/" 2>/dev/null || true

# Vérifier la copie
BACKUP_FILE_COUNT=$(find "$BACKUP_DIR/data" -type f 2>/dev/null | wc -l)
echo "   • Fichiers sauvegardés: $BACKUP_FILE_COUNT"

if [ "$BACKUP_FILE_COUNT" -lt "$DATA_FILE_COUNT" ]; then
    error_exit "Le backup des données est incomplet! ($BACKUP_FILE_COUNT/$DATA_FILE_COUNT fichiers)"
fi

# Créer un manifest du backup
cat > "$BACKUP_DIR/MANIFEST.txt" << EOF
Backup créé le: $(date '+%Y-%m-%d %H:%M:%S')
Version source: $CURRENT_VERSION
Version cible: $NEW_VERSION
Répertoire de données: $DATA_DIR
Répertoire d'installation: $INSTALL_DIR
Nombre de fichiers de données: $BACKUP_FILE_COUNT

Liste des fichiers de données:
$(cd "$BACKUP_DIR/data" && find . -type f | sort)

EOF

echo -e "${GREEN}✅ Backup des données créé avec succès${NC}"
echo "   • $BACKUP_FILE_COUNT fichiers sauvegardés"
echo "   • Manifest: $BACKUP_DIR/MANIFEST.txt"

# Backup de l'application actuelle
echo ""
echo "📦 Sauvegarde de l'application actuelle..."
if command -v rsync &>/dev/null; then
    rsync -a --exclude 'venv/' "$INSTALL_DIR/" "$BACKUP_DIR/app/" || error_exit "Échec du backup de l'application"
else
    cp -a "$INSTALL_DIR"/* "$BACKUP_DIR/app/" || error_exit "Échec du backup de l'application"
    rm -rf "$BACKUP_DIR/app/venv" 2>/dev/null || true
fi
echo -e "${GREEN}✅ Backup de l'application créé${NC}"

# Confirmation avant de continuer
echo ""
echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${YELLOW}⚠️  BACKUP COMPLET CRÉÉ - Prêt pour la mise à jour${NC}"
echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
echo "Backup des données: $BACKUP_DIR"
echo "Fichiers sauvegardés: $BACKUP_FILE_COUNT"
echo ""
echo -e "${YELLOW}Continuer avec la mise à jour? [o/N]${NC}"
read -r response
if [[ ! "$response" =~ ^[oO]$ ]]; then
    echo "Mise à jour annulée. Le backup est conservé dans: $BACKUP_DIR"
    exit 0
fi

# Arrêter l'application si elle tourne
print_header "🛑 Arrêt de l'application en cours"
if pgrep -f "password_manager.py" > /dev/null; then
    echo "Arrêt des processus en cours..."
    pkill -f "password_manager.py" || true
    sleep 2
    echo -e "${GREEN}✅ Application arrêtée${NC}"
else
    echo "Aucune instance en cours d'exécution"
fi

# Mise à jour des fichiers de l'application
print_header "📦 Mise à jour des fichiers de l'application"
echo "Copie des nouveaux fichiers..."

if command -v rsync &>/dev/null; then
    rsync -a \
        --exclude '.git/' \
        --exclude '.gitignore' \
        --exclude 'venvpwdmanager/' \
        --exclude 'venv/' \
        --exclude 'venv-dev/' \
        --exclude '__pycache__/' \
        --exclude '*/__pycache__/' \
        --exclude '**/__pycache__/' \
        --exclude 'data/' \
        --exclude 'logs/' \
        --exclude '*.pyc' \
        --exclude '.pytest_cache/' \
        --exclude '.vscode/' \
        "$SCRIPT_DIR/" "$INSTALL_DIR/" \
        || error_exit "Impossible de copier les nouveaux fichiers"
else
    cp -a "$SCRIPT_DIR"/* "$INSTALL_DIR/" || error_exit "Impossible de copier les nouveaux fichiers"
    rm -rf "$INSTALL_DIR/.git" "$INSTALL_DIR/.gitignore" \
        "$INSTALL_DIR/venvpwdmanager" \
        "$INSTALL_DIR/venv-dev" \
        "$INSTALL_DIR/__pycache__" "$INSTALL_DIR/src/__pycache__" \
        "$INSTALL_DIR/tests/__pycache__" \
        "$INSTALL_DIR/.pytest_cache" \
        "$INSTALL_DIR/.vscode" > /dev/null 2>&1 || true
    find "$INSTALL_DIR" -name "*.pyc" -delete 2>/dev/null || true
fi

echo -e "${GREEN}✅ Fichiers de l'application mis à jour${NC}"

# Mise à jour de l'environnement virtuel
print_header "🐍 Mise à jour de l'environnement virtuel"
if [ -d "$VENV_DIR" ]; then
    echo "Suppression de l'ancien environnement virtuel..."
    rm -rf "$VENV_DIR"
fi

echo "Création du nouvel environnement virtuel..."
python3 -m venv --system-site-packages "$VENV_DIR" || error_exit "Impossible de créer l'environnement virtuel"
source "$VENV_DIR/bin/activate"

echo "Mise à jour de pip..."
pip install --upgrade pip > /dev/null 2>&1 || error_exit "Impossible de mettre à jour pip"

echo "Installation des dépendances Python..."
filter_pip_requirements
if [ -s "$FILTERED_REQUIREMENTS" ]; then
    pip install -r "$FILTERED_REQUIREMENTS" > /dev/null 2>&1 || error_exit "Impossible d'installer les dépendances"
fi

echo -e "${GREEN}✅ Environnement virtuel mis à jour${NC}"

# Vérification des permissions sur les données
print_header "🔒 Vérification et mise à jour des permissions"
echo "Vérification du répertoire de données..."

# S'assurer que les permissions sont correctes (ne change PAS les propriétaires)
chmod 2775 "$DATA_DIR" 2>/dev/null || true

# Mettre à jour les permissions des fichiers pour la compatibilité 0.3.0-beta
echo "Mise à jour des permissions des fichiers sensibles (mode 600)..."
find "$DATA_DIR" -name "*.db" -type f -exec chmod 600 {} \; 2>/dev/null || true
find "$DATA_DIR" -name "salt_*.bin" -type f -exec chmod 600 {} \; 2>/dev/null || true

echo -e "${GREEN}✅ Permissions mises à jour${NC}"

# Mise à jour du lanceur desktop
print_header "📝 Mise à jour du lanceur"
DESKTOP_FILE="$APP_NAME.desktop"
SYSTEM_APPS_DIR="/usr/share/applications"
if [ -f "$INSTALL_DIR/$DESKTOP_FILE" ]; then
    cp "$INSTALL_DIR/$DESKTOP_FILE" "$SYSTEM_APPS_DIR/" || error_exit "Impossible de copier le fichier .desktop"
    sed -i "s|Exec=.*|Exec=$INSTALL_DIR/run.sh|g" "$SYSTEM_APPS_DIR/$DESKTOP_FILE"
    chmod +x "$SYSTEM_APPS_DIR/$DESKTOP_FILE"
    update-desktop-database "$SYSTEM_APPS_DIR" 2>/dev/null || true
    echo -e "${GREEN}✅ Lanceur mis à jour${NC}"
fi

# Vérification finale
print_header "🔍 Vérification de la mise à jour"
UPDATED_VERSION=$(python3 -c "import sys; sys.path.insert(0, '$INSTALL_DIR'); from src.version import __version__; print(__version__)" 2>/dev/null || echo "erreur")

if [ "$UPDATED_VERSION" = "$NEW_VERSION" ]; then
    echo -e "${GREEN}✅ Version mise à jour: $UPDATED_VERSION${NC}"
else
    error_exit "La version installée ($UPDATED_VERSION) ne correspond pas à la version attendue ($NEW_VERSION)"
fi

# Vérifier l'intégrité des données
DATA_FILE_COUNT_AFTER=$(find "$DATA_DIR" -type f 2>/dev/null | wc -l)
if [ "$DATA_FILE_COUNT_AFTER" -lt "$DATA_FILE_COUNT" ]; then
    error_exit "PERTE DE DONNÉES DÉTECTÉE! Fichiers avant: $DATA_FILE_COUNT, après: $DATA_FILE_COUNT_AFTER"
fi

echo -e "${GREEN}✅ Toutes les vérifications sont passées${NC}"

# Rotation des backups (garder les 10 plus récents)
print_header "🔄 Rotation des backups"
echo "Conservation des 10 backups les plus récents..."
cd "$BACKUP_ROOT"
ls -t | tail -n +11 | xargs -r rm -rf
BACKUP_COUNT=$(ls -1 | wc -l)
echo "Backups conservés: $BACKUP_COUNT"

# Résumé final
echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║                                                              ║"
echo "║             ✅ MISE À JOUR RÉUSSIE !                         ║"
echo "║                                                              ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""
echo "📊 Résumé de la mise à jour:"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Version précédente    : $CURRENT_VERSION"
echo "  Version installée     : $UPDATED_VERSION"
echo "  Fichiers de données   : $DATA_FILE_COUNT_AFTER (aucune perte)"
echo "  Backup créé dans      : $BACKUP_DIR"
echo "  Logs                  : /tmp/update-password-manager.log"
echo ""
echo "🎯 L'application peut maintenant être relancée:"
echo "   • Via le menu Applications"
echo "   • Ou avec: $INSTALL_DIR/run.sh"
echo ""
echo "💾 En cas de problème, restaurez le backup:"
echo "   sudo cp -a $BACKUP_DIR/data/* $DATA_DIR/"
echo "   sudo cp -a $BACKUP_DIR/app/* $INSTALL_DIR/"
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
