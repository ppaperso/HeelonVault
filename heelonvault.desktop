[Desktop Entry]
Version=0.4.0-Bêta
Type=Application
Name=HeelonVault
Comment=Gestionnaire de mots de passe sécurisé (Multi-utilisateurs avec sauvegarde automatique)
Exec=/opt/heelonvault/run.sh
Icon=heelonvault
Terminal=false
Categories=Utility;Security;
Keywords=password;security;encryption;vault;
StartupNotify=true
StartupWMClass=org.heelonys.heelonvault
